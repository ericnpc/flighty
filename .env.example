# URL of the Playwright scraper service (see scraper/README.md).
# In dev: run the scraper locally and expose via ngrok, then paste the ngrok URL here.
# In Vercel: set this in the project's environment variables.
SCRAPER_URL=http://localhost:8787

# Shared secret between the Next.js API route and the scraper service.
# Set the same value in scraper/.env.
SCRAPER_TOKEN=change-me
